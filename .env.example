# SUPABASE (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=your_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# SUPABASE AUTH - Google OAuth (local dev; required for "Continue with Google")
# Create a Web OAuth client at https://console.cloud.google.com/apis/credentials
# Add Authorized redirect URI: http://127.0.0.1:54321/auth/v1/callback
# Then run: supabase stop; supabase start
SUPABASE_AUTH_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=

# STRIPE (Dashboard -> Developers -> API Keys)
# Use test keys for local development.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_test_xxx

# APP SECURITY
# Generate a random 32+ char value (do not commit real value).
ENCRYPTION_SECRET=replace_with_random_secret
CRON_AUTH_TOKEN=replace_with_random_cron_token
ADMIN_AUTH_TOKEN=replace_with_random_admin_token
FREE_SESSION_SECRET=replace_with_random_free_session_secret
FINGERPRINT_SALT=replace_with_random_fingerprint_salt
NEXT_PUBLIC_APP_BASE_URL=http://localhost:3000

# OPTIONAL ALERTING
TELEGRAM_BOT_TOKEN=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# OPTIONAL — Figma MCP (Cursor design-to-code)
# Get a token: Figma → Settings → Security → Personal access tokens
# Set in Cursor: Settings → MCP → "Framelink MCP for Figma" → Edit → env FIGMA_API_KEY
FIGMA_API_KEY=
